{
  "version": 2,
  "builds": [
    {
      "src": "./app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/users/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/api/grounds/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/api/turfs/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/api/bookings/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/api/contact/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/api/health",
      "dest": "/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/app.js"
    }
  ]
}
